# ─────────────────────────────────────────────────────────────────────────────
# AXIOM Terminal — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored and will NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# AWS Bedrock — required for /api/chat (Claude AI)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# Web3Forms — required for the Contact form (get key at app.web3forms.com)
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_access_key_here
